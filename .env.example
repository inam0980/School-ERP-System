# ─────────────────────────────────────────────────────────────
#  .env  —  Copy this to the server and fill in real values.
#           Never commit this file to version control.
# ─────────────────────────────────────────────────────────────

SECRET_KEY=change-me-use-python-secrets-token-hex-50
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,SERVER_IP

# PostgreSQL
DB_NAME=school_db
DB_USER=django_user
DB_PASSWORD=StrongProductionPassword!
DB_HOST=localhost
DB_PORT=5432

# Optional – enable GPT-4o-mini summaries in AI module
OPENAI_API_KEY=

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=smtp_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Al-Kawthar ERP <noreply@example.com>
